# ============================================================
#  TutorMath – Variables de entorno
#  Copia este archivo como .env para desarrollo local.
#  En Railway configura cada variable en el panel de Variables.
# ============================================================

# 🔐 Clave secreta de Flask (genera una aleatoria y larga)
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga-y-segura

# 🗄️ Base de datos PostgreSQL
#    Railway la inyecta automáticamente cuando añades el plugin Postgres
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_bd

# 🔑 Código exclusivo para que los docentes puedan registrarse
CODIGO_REGISTRO_DOCENTE=TUTOR-2026

# 📱 URL de descarga del APK de la app móvil
APK_DOWNLOAD_URL=https://github.com/pieroramireztesis-arch/movil_tesis/releases/download/v1.0/app-release.apk

# 📧 Correo de envío (cuenta Gmail con App Password habilitado)
MAIL_USERNAME=tu@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 🖼️ Ruta donde la API guarda los desarrollos de los alumnos
#    En Railway apunta a la URL de la API o a un volumen compartido
DESARROLLOS_ALUMNO_PATH=/app/static/desarrollos_alumno